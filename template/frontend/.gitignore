# =========================
# UNIVERSAL .gitignore
# =========================

# -------------------------
# OS FILES
# -------------------------
.DS_Store
Thumbs.db
desktop.ini

# -------------------------
# LOGS
# -------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -------------------------
# ENV FILES
# -------------------------
.env
.env.*
!.env.example

# -------------------------
# NODE / JAVASCRIPT
# -------------------------
node_modules/
dist/
build/
.next/
out/
coverage/
.cache/
.parcel-cache/
.vite/
.vercel/
.netlify/

# React Native / Expo
.expo/
.expo-shared/
android/
ios/
*.keystore

# -------------------------
# TYPESCRIPT
# -------------------------
*.tsbuildinfo

# -------------------------
# PYTHON
# -------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.env/
.python-version

# -------------------------
# JAVA
# -------------------------
*.class
*.jar
*.war
*.ear
.gradle/
build/

# -------------------------
# PHP
# -------------------------
vendor/

# -------------------------
# RUBY
# -------------------------
.bundle/
vendor/bundle/

# -------------------------
# GO
# -------------------------
bin/
pkg/

# -------------------------
# RUST
# -------------------------
target/
Cargo.lock

# -------------------------
# C / C++
# -------------------------
*.o
*.obj
*.exe
*.dll

# -------------------------
# DATABASES
# -------------------------
*.sqlite
*.sqlite3
*.db

# -------------------------
# IDES / EDITORS
# -------------------------
.vscode/
.idea/
*.swp
*.swo

# -------------------------
# TESTING
# -------------------------
coverage/
.nyc_output/

# -------------------------
# TEMP FILES
# -------------------------
tmp/
temp/
*.tmp

# -------------------------
# MEDIA / GENERATED FILES
# -------------------------
uploads/
public/uploads/
storage/
generated/

# -------------------------
# PACKAGE MANAGERS
# -------------------------
package-lock.json
yarn.lock
pnpm-lock.yaml

# Uncomment if you WANT lockfiles
# !package-lock.json
# !yarn.lock
# !pnpm-lock.yaml

# -------------------------
# DOCKER
# -------------------------
.docker/

# -------------------------
# SECRETS
# -------------------------
*.pem
*.key
*.crt

# -------------------------
# MISC
# -------------------------
*.zip
*.tar
*.gz
*.rar